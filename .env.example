DJANGO_SECRET_KEY=replace-with-secure-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_SETTINGS_MODULE=config.settings.dev

# Production-only security settings
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True

# Preferred for Supabase and deployment
DATABASE_URL=postgresql://postgres:password@db.example.supabase.co:5432/postgres?sslmode=require
POSTGRES_CONN_MAX_AGE=600

# Optional fallback (used only when DATABASE_URL is empty)
POSTGRES_DB=healthsync
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_SSLMODE=prefer

API_PAGE_SIZE=10
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7
